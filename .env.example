# Copy to .env (or export in your shell) and adjust to your setup.
# The agent talks to any OpenAI-compatible server hosting an open-weights model.
# Defaults target a local Ollama instance — no cloud, no API keys, no vendor.

# Endpoint URL (Ollama default shown). For vLLM/llama.cpp/TGI, point at theirs,
# e.g. http://localhost:8000/v1
MOL_SCREEN_LLM_BASE_URL=http://localhost:11434/v1

# Open-weights model name as your server exposes it.
# Ollama examples: qwen2.5:7b-instruct, llama3.1:8b, mistral-nemo
# vLLM example:    Qwen/Qwen2.5-7B-Instruct
MOL_SCREEN_LLM_MODEL=qwen2.5:7b-instruct

# Most local servers ignore the key; the OpenAI client just needs it non-empty.
MOL_SCREEN_LLM_API_KEY=not-needed

# Quick start with Ollama:
#   ollama serve
#   ollama pull qwen2.5:7b-instruct
