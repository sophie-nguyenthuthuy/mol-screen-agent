# Copy to .env (or export in your shell) and fill in.
# AWS credentials for Bedrock — uses the standard AWS credential chain, so any
# of these work: env vars, ~/.aws/credentials profile, SSO, instance role.
AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_SESSION_TOKEN=...
# AWS_PROFILE=default

# Bedrock model id. Must be a Claude model you have enabled in this region.
# Default is a broadly-available cross-region inference profile. Point this at a
# newer Claude once enabled, e.g. a Sonnet 4.6 / Opus 4.8 inference profile.
BEDROCK_MODEL_ID=us.anthropic.claude-3-5-sonnet-20241022-v2:0
